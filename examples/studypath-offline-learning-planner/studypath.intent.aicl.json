{
  "schema": "AICL-AgentProjectIntent-v1",
  "project": {
    "name": "StudyPath",
    "description": "A cross-platform offline learning plan builder for personalized study schedules, local practice, and privacy-preserving progress tracking.",
    "public_demo": true,
    "status": "reference_architecture"
  },
  "intent_origin": {
    "type": "agent",
    "originator": "agent://aicl/demo-initiator",
    "human_owner": "Marc Johnston",
    "organization": "NeuroSync AI Dynamics Pty Ltd",
    "requires_human_approval_above": "R2"
  },
  "scenario": {
    "learner_goal": "Prepare for an introductory Python assessment in 21 days.",
    "weekday_minutes_available": 45,
    "weekend_minutes_available": 90,
    "weak_areas": [
      "loops",
      "functions"
    ],
    "runtime_mode": "offline_first"
  },
  "icc_ref": "studypath.icc.json",
  "targets": {
    "android": {
      "enabled": true
    },
    "web": {
      "enabled": true
    },
    "windows": {
      "enabled": true
    }
  },
  "non_goals": [
    "real_exam_board_alignment",
    "guaranteed_exam_outcome",
    "cloud_student_tracking",
    "analytics",
    "backend_services",
    "paid_services"
  ],
  "maintain": [
    "local_first_storage",
    "deterministic_local_adaptation",
    "accessibility_baseline",
    "curriculum_provenance",
    "student_data_privacy"
  ],
  "avoid": [
    "guaranteed_exam_outcome_claims",
    "cloud_student_tracking",
    "hidden_analytics",
    "unsupported_pedagogical_claims",
    "copyrighted_curriculum_ingestion"
  ],
  "required_agents": [
    "IntentAgent",
    "CurriculumAgent",
    "PlannerAgent",
    "QuizAgent",
    "AdaptationAgent",
    "AccessibilityAgent",
    "PrivacyAgent",
    "ProofAgent",
    "MaterializationAgent"
  ],
  "proof_gates": [
    "PG01",
    "PG02",
    "PG03",
    "PG04",
    "PG05",
    "PG06",
    "PG07",
    "PG08",
    "PG09"
  ],
  "materialization_outputs": [
    "studypath.target.android.aicl.json",
    "studypath.target.web.aicl.json",
    "studypath.target.windows.aicl.json"
  ]
}
