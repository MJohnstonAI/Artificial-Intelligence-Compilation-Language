{
  "schema": "AICL-TargetBrief-v1",
  "project": "StudyPath",
  "target": "windows",
  "artifact": "win-msix",
  "materialization_scope": "target_brief_only",
  "layout": {
    "mode": "windowed desktop layout",
    "keyboard_first_paths": true
  },
  "runtime_constraints": {
    "offline_first": true,
    "analytics": "none",
    "backend": "none",
    "ads": "none",
    "payments": "none",
    "storage": "local_app_data_storage",
    "network_requirement": "none"
  },
  "local_artifacts": [
    "local_curriculum_pack",
    "local_progress_state",
    "local_practice_queue",
    "user_initiated_export_only"
  ],
  "accessibility": {
    "baseline": "accessibility_baseline",
    "keyboard_navigation": true,
    "high_contrast_support": true,
    "screen_reader_labels": true,
    "reduced_motion_support": true,
    "no_color_only_progress": true
  },
  "proof_gate_refs": [
    "PG01",
    "PG02",
    "PG03",
    "PG04",
    "PG05",
    "PG06",
    "PG07",
    "PG08",
    "PG09"
  ]
}
