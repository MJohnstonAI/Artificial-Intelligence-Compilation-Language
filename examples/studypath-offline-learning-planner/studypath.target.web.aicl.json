{
  "schema": "AICL-TargetBrief-v1",
  "project": "StudyPath",
  "target": "web",
  "artifact": "web-pwa",
  "materialization_scope": "target_brief_only",
  "layout": {
    "mode": "offline-capable PWA concept",
    "responsive": true
  },
  "runtime_constraints": {
    "offline_first": true,
    "analytics": "none",
    "backend": "none",
    "ads": "none",
    "payments": "none",
    "storage": "IndexedDB/local storage abstraction",
    "service_worker": "allowed_only_for_offline_cache",
    "external_analytics": "none",
    "backend_required": false
  },
  "local_artifacts": [
    "local_curriculum_pack",
    "local_progress_state",
    "local_practice_queue",
    "user_initiated_export_only"
  ],
  "accessibility": {
    "baseline": "accessibility_baseline",
    "readable_typography": true,
    "screen_reader_labels": true,
    "keyboard_navigation": true,
    "high_contrast": true,
    "reduced_motion": true,
    "no_color_only_progress": true
  },
  "proof_gate_refs": [
    "PG01",
    "PG02",
    "PG03",
    "PG04",
    "PG05",
    "PG06",
    "PG07",
    "PG08",
    "PG09"
  ]
}
